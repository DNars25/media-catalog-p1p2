generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [unaccent]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum TitleType {
  MOVIE
  TV
}

enum InternalStatus {
  AGUARDANDO_DOWNLOAD
  DISPONIVEL
  INDISPONIVEL
}

enum TvStatus {
  EM_ANDAMENTO
  FINALIZADA
}

enum RequestStatus {
  ABERTO
  EM_ANDAMENTO
  EM_PROGRESSO
  CONCLUIDO
  REJEITADO
}

enum PreferredSystem {
  P1
  P2
  AMBOS
}

enum RequestSource {
  ADMIN
  VITRINE
  PEDIDO
}

model User {
  id           String    @id @default(uuid())
  name         String
  username     String?   @unique
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  titles             Title[]
  requests           Request[]
  completedRequests  Request[]  @relation("completedRequests")
  auditLogs          AuditLog[]
}

model Title {
  id             String         @id @default(uuid())
  tmdbId         Int
  type           TitleType
  title          String
  overview       String?        @db.Text
  posterUrl      String?
  releaseYear    Int?
  genres         Json           @default("[]")
  tvSeasons      Int?
  tvEpisodes     Int?
  tvStatus       TvStatus?
  internalStatus InternalStatus @default(AGUARDANDO_DOWNLOAD)
  audioType      String?
  hasP1          Boolean        @default(false)
  hasP2          Boolean        @default(false)
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  requests       Request[]
  episodes       TitleEpisode[]

  @@unique([tmdbId, type])
  @@index([title])
  @@index([tmdbId])
  @@index([hasP1])
  @@index([hasP2])
  @@index([internalStatus])
}

model TitleEpisode {
  id        String   @id @default(uuid())
  titleId   String
  title     Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  season    Int
  episode   Int
  createdAt DateTime @default(now())

  @@unique([titleId, season, episode])
  @@index([titleId])
}

model Request {
  id               String          @id @default(uuid())
  requestedTitle   String
  type             TitleType
  tmdbId           Int?
  posterUrl        String?
  notes            String?         @db.Text
  requestedBy      String?
  audioType        String?
  preferredSystem  PreferredSystem?
  status           RequestStatus   @default(ABERTO)
  createdById      String
  createdBy        User            @relation(fields: [createdById], references: [id])
  isUpdate         Boolean         @default(false)
  isCorrection     Boolean         @default(false)
  seasonNumber     Int?
  linkedTitleId    String?
  linkedTitle      Title?          @relation(fields: [linkedTitleId], references: [id])
  source           RequestSource   @default(ADMIN)
  priority         Boolean         @default(false)
  completedById    String?
  completedBy      User?           @relation("completedRequests", fields: [completedById], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([linkedTitleId])
  @@index([type, status])
  @@index([isCorrection, status])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // 'PEDIDO' | 'CORRECAO'
  title     String
  body      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
}
