generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TitleType {
  MOVIE
  TV
}

enum InternalStatus {
  AGUARDANDO_DOWNLOAD
  DISPONIVEL
  INDISPONIVEL
}

enum TvStatus {
  EM_ANDAMENTO
  FINALIZADA
}

enum RequestStatus {
  ABERTO
  EM_PROGRESSO
  CONCLUIDO
  REJEITADO
}

enum PreferredSystem {
  P1
  P2
  AMBOS
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  titles       Title[]
  requests     Request[]
  auditLogs    AuditLog[]
}

model Title {
  id             String         @id @default(uuid())
  tmdbId         Int
  type           TitleType
  title          String
  overview       String?        @db.Text
  posterUrl      String?
  releaseYear    Int?
  genres         Json           @default("[]")
  tvSeasons      Int?
  tvEpisodes     Int?
  tvStatus       TvStatus?
  internalStatus InternalStatus @default(AGUARDANDO_DOWNLOAD)
  hasP1          Boolean        @default(false)
  hasP2          Boolean        @default(false)
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  requests       Request[]

  @@unique([tmdbId, type])
  @@index([title])
  @@index([hasP1])
  @@index([hasP2])
  @@index([internalStatus])
}

model Request {
  id               String          @id @default(uuid())
  requestedTitle   String
  type             TitleType
  tmdbId           Int?
  notes            String?         @db.Text
  preferredSystem  PreferredSystem?
  status           RequestStatus   @default(ABERTO)
  createdById      String
  createdBy        User            @relation(fields: [createdById], references: [id])
  linkedTitleId    String?
  linkedTitle      Title?          @relation(fields: [linkedTitleId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}
